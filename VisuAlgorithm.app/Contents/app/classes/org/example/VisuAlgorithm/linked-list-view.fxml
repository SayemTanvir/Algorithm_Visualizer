<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.VisuAlgorithm.LinkedListController"
           styleClass="root">

    <!-- 🎨 Animated DSA background layer (floating graphs & trees) -->
    <Pane fx:id="backgroundAnimationPane" pickOnBounds="false"/>

    <!-- 📋 Main content overlay -->
    <VBox alignment="TOP_CENTER" spacing="32">
        <padding>
            <Insets top="42" left="0" right="0" bottom="0"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <padding>
                <Insets left="24" right="24" top="0" bottom="0"/>
            </padding>
            <Button text="← Back" onAction="#onBack"
                    style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 8 16 8 16;"/>
            <Label text="Linked List" styleClass="dashboard-title"/>
            <Region HBox.hgrow="ALWAYS"/>
<!--            <Label fx:id="statusLabel" text="Choose a linked list type"-->
<!--                   style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;"/>-->
        </HBox>

        <!-- Subtitle -->
        <Label text="Choose the linked list visualizer you want"
               style="-fx-text-fill: #93c5fd; -fx-font-size: 18px;"/>

        <!-- 🎴 Cards (like home page) -->
        <FlowPane alignment="CENTER" hgap="32" vgap="32" prefWrapLength="960" style="-fx-padding:22;">

            <!-- Singly Linked List Card -->
            <VBox styleClass="card" spacing="10" alignment="CENTER" onMouseClicked="#gotoSinglyLinkedList">
                <ImageView fitHeight="90" fitWidth="160">
                    <image>
                        <Image url="@/Images/linked_list.png"/>
                    </image>
                </ImageView>
                <Label text="Singly Linked List" style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#8ac7ff;"/>
                <Label text="One-way traversal" style="-fx-text-fill:#ffd580"/>
            </VBox>

            <!-- Doubly Linked List Card -->
            <VBox styleClass="card" spacing="10" alignment="CENTER" onMouseClicked="#gotoDoublyLinkedList">
                <ImageView fitHeight="90" fitWidth="160">
                    <image>
                        <Image url="@/Images/doubly_linked_list.png"/>
                    </image>
                </ImageView>
                <Label text="Doubly Linked List" style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#8ac7ff;"/>
                <Label text="Forward &amp; backward" style="-fx-text-fill:#ffd580"/>
            </VBox>

            <!-- Circular Linked List Card -->
            <VBox styleClass="card" spacing="10" alignment="CENTER" onMouseClicked="#gotoCircularLinkedList">
                <ImageView fitHeight="90" fitWidth="160">
                    <image>
                        <Image url="@/Images/circular_linked_list.png"/>
                    </image>
                </ImageView>
                <Label text="Circular Linked List" style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#8ac7ff;"/>
                <Label text="Last node → head" style="-fx-text-fill:#ffd580"/>
            </VBox>

        </FlowPane>
    </VBox>
</StackPane>