<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.VisuAlgorithm.DoublyLinkedListController"
            style="-fx-background-color: #eef2ff;">

    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #1e293b, #334155);">
                <padding>
                    <Insets top="12" right="16" bottom="12" left="16"/>
                </padding>

                <Button text="← Back"
                        onAction="#onBack"
                        style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                <Label text="Singly Linked List"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="headerStatusLabel"
                       text="Ready."
                       style="-fx-text-fill: #dbeafe;"/>
            </HBox>

            <VBox spacing="10" style="-fx-background-color: white;">
                <padding>
                    <Insets top="12" right="16" bottom="12" left="16"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Value:"/>
                    <TextField fx:id="valueField" promptText="value" prefWidth="90"/>

                    <Label text="Index:"/>
                    <TextField fx:id="indexField" promptText="index" prefWidth="90"/>

                    <Button text="Insert Head" onAction="#onInsertHead"/>
                    <Button text="Insert Tail" onAction="#onInsertTail"/>
                    <Button text="Insert At" onAction="#onInsertAt"/>
                    <Button text="Random" onAction="#onRandom"/>
                    <Button text="Delete Head" onAction="#onDeleteHead"/>
                    <Button text="Delete Tail" onAction="#onDeleteTail"/>
                    <Button text="Delete At" onAction="#onDeleteAt"/>
                    <Button text="Search" onAction="#onSearch"/>
                    <Button text="Traverse" onAction="#onTraverse"/>
                    <Button text="Sort" onAction="#onSort"/>
                    <Button text="Clear" onAction="#onClear"/>
                </HBox>

                <Label fx:id="statusLabel" text="Ready."/>
            </VBox>
        </VBox>
    </top>

    <center>
        <ScrollPane pannable="true"
                    fitToWidth="false"
                    fitToHeight="false"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED">
            <Pane fx:id="canvas"
                  prefWidth="1800"
                  prefHeight="700"
                  style="-fx-background-color: linear-gradient(to bottom, #eef2ff, #f8fafc);"/>
        </ScrollPane>
    </center>

</BorderPane>