<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #eef2ff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.VisuAlgorithm.QueueController">

    <fx:define>
        <ToggleGroup fx:id="modeGroup" />
        <ToggleGroup fx:id="priorityTypeGroup" />
    </fx:define>

    <top>
        <VBox spacing="0">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: linear-gradient(to right, #1e293b, #334155);">
                <padding>
                    <Insets bottom="12" left="16" right="16" top="12" />
                </padding>

                <Button fx:id="backBtn" onAction="#onBack" style="-fx-background-color: rgba(255,255,255,0.12);                                -fx-text-fill: white;                                -fx-background-radius: 12;                                -fx-padding: 8 14 8 14;                                -fx-font-weight: bold;" text="← Back" />

                <Label style="-fx-text-fill: white;                               -fx-font-size: 18px;                               -fx-font-weight: bold;" text="Queue Visualizer" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="headerStatusLabel" style="-fx-text-fill: #dbeafe;                               -fx-font-size: 12px;" text="Ready." />
            </HBox>

            <!-- Main controls panel -->
            <VBox spacing="12" style="-fx-background-color: #ffffff;                          -fx-border-color: #dbeafe;                          -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets bottom="14" left="16" right="16" top="14" />
                </padding>

                <!-- Row 1 -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Mode:" />

                    <RadioButton fx:id="rbQueue" onAction="#onModeChanged" selected="true" text="Queue">
                  <toggleGroup>
                     <ToggleGroup fx:id="modeGroup" />
                  </toggleGroup></RadioButton>

                    <RadioButton fx:id="rbDeque" onAction="#onModeChanged" text="Deque" toggleGroup="$modeGroup" />

                    <RadioButton fx:id="rbPriority" onAction="#onModeChanged" text="Priority Queue" toggleGroup="$modeGroup" />

                    <RadioButton fx:id="rbCircular" onAction="#onModeChanged" text="Circular Queue" toggleGroup="$modeGroup" />

                    <Separator orientation="VERTICAL" prefHeight="28" />

                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Value:" />
                    <TextField fx:id="valueField" prefWidth="110" promptText="Enter value" />

                    <Label fx:id="priorityLabel" managed="false" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Priority:" visible="false" />
                    <TextField fx:id="priorityField" managed="false" prefWidth="100" promptText="Priority" visible="false" />

                    <Label fx:id="capacityLabel" managed="false" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Capacity:" visible="false" />
                    <TextField fx:id="capacityField" managed="false" prefWidth="90" promptText="Size" visible="false" />

                    <Button fx:id="setCapacityBtn" managed="false" onAction="#onSetCapacity" style="-fx-background-color: #dbeafe;                                    -fx-text-fill: #1e3a8a;                                    -fx-background-radius: 10;                                    -fx-font-weight: bold;" text="Set Capacity" visible="false" />

                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Row 2 -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button fx:id="enqueueBtn" onAction="#onEnqueue" style="-fx-background-color: #2563eb;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Enqueue" />

                    <Button fx:id="dequeueBtn" onAction="#onDequeue" style="-fx-background-color: #0f766e;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Dequeue" />

                    <Button fx:id="randomBtn" onAction="#onRandom" style="-fx-background-color: black; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;" text="Random"/>

                    <Button fx:id="pushFrontBtn" managed="false" onAction="#onPushFront" style="-fx-background-color: #7c3aed;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Push Front" visible="false" />

                    <Button fx:id="pushRearBtn" managed="false" onAction="#onPushRear" style="-fx-background-color: #6366f1;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Push Rear" visible="false" />

                    <Button fx:id="popFrontBtn" managed="false" onAction="#onPopFront" style="-fx-background-color: #ea580c;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Pop Front" visible="false" />

                    <Button fx:id="popRearBtn" managed="false" onAction="#onPopRear" style="-fx-background-color: #dc2626;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Pop Rear" visible="false" />

                    <Button fx:id="peekBtn" onAction="#onFront" style="-fx-background-color: #475569;                                    -fx-text-fill: white;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Front" />

                    <Button onAction="#onClear" style="-fx-background-color: #fee2e2;                                    -fx-text-fill: #991b1b;                                    -fx-background-radius: 12;                                    -fx-font-weight: bold;" text="Clear" />

                    <Separator orientation="VERTICAL" prefHeight="28" />

                    <HBox fx:id="priorityTypeBox" alignment="CENTER_LEFT" managed="false" spacing="10" visible="false">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Priority type:" />
                        <RadioButton fx:id="rbMaxPriority" onAction="#onPriorityTypeChanged" selected="true" text="Max">
                     <toggleGroup>
                        <ToggleGroup fx:id="priorityTypeGroup" />
                     </toggleGroup></RadioButton>
                        <RadioButton fx:id="rbMinPriority" onAction="#onPriorityTypeChanged" text="Min" toggleGroup="$priorityTypeGroup" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Front:" />
                    <Label fx:id="frontLabel" text="-1" />

                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Rear:" />
                    <Label fx:id="rearLabel" text="-1" />
                </HBox>

                <!-- Row 3 -->
                <Label fx:id="modeHintLabel" style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="" />

                <Label fx:id="statusLabel" style="-fx-text-fill: #334155; -fx-font-size: 13px;" text="Ready." />
            </VBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollPane"
                    pannable="true"
                    fitToWidth="false"
                    fitToHeight="false"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;">

            <Pane fx:id="canvas"
                  prefWidth="2600"
                  prefHeight="1200"
                  style="-fx-background-color: linear-gradient(to bottom, #eef2ff, #f8fafc);"/>
        </ScrollPane>
    </center>

</BorderPane>
