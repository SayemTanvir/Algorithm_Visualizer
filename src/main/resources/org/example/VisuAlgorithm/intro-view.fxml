<StackPane fx:id="rootPane"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.VisuAlgorithm.IntroController"
           style="-fx-background-color: linear-gradient(to bottom, #05060a, #111827);">

    <Pane fx:id="bgPane" />

    <VBox alignment="CENTER" spacing="16">
        <Label fx:id="titleLabel"
               text="VISUALGORITHM"
               style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: white;" />

        <Label fx:id="subLabel"
               text="Algorithm Visualizer"
               style="-fx-font-size: 18px; -fx-text-fill: rgba(255,255,255,0.75);" />
    </VBox>

</StackPane>