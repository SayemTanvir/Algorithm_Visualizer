<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.VisuAlgorithm.BSTController" style="-fx-background-color: #f4f6f8;">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0"
                  style="-fx-background-color: linear-gradient(to right, #1e293b, #334155); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <padding>
                    <Insets left="20.0" right="20.0" top="12.0" bottom="12.0" />
                </padding>
                <children>
                    <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBackButton" prefHeight="32.0"
                            style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                            text="← Back" />
                    <Label text="Binary Search Tree" textFill="white">
                        <font>
                            <Font name="System Bold" size="24.0" />
                        </font>
                    </Label>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="screenshotBtn" onAction="#takeScreenshot" prefHeight="32.0"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 6;"/>
                    <Button fx:id="recordBtn" onAction="#toggleRecording" prefHeight="32.0"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 6;"/>
                </children>
            </HBox>

            <StackPane>
                <ToolBar fx:id="buildToolbar"
                         style="-fx-background-color: #ffffff; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0; -fx-padding: 12 15;">

                    <Label text="Value:" style="-fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                    <TextField fx:id="insertField" onAction="#handleInsert" prefWidth="80" promptText="e.g. 42"
                               style="-fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 4;"/>
                    <Button onAction="#handleInsert" text="Insert"
                            style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-cursor: hand;"/>

                    <Separator style="-fx-padding: 0 5 0 5;" />

                    <Button onAction="#deleteSelected" text="Delete"
                            style="-fx-background-color: #fee2e2; -fx-text-fill: #b91c1c; -fx-border-color: #f87171; -fx-border-radius: 6; -fx-cursor: hand;"/>

                    <Separator style="-fx-padding: 0 5 0 5;" />

                    <Button onAction="#generateRandomTree" text="Random Tree"
                            style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-cursor: hand;"/>
                    <Button onAction="#clearTree" text="Clear"
                            style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-cursor: hand;"/>

                    <Separator style="-fx-padding: 0 5 0 5;" />

                    <Button onAction="#switchToAlgoMode" text="Algo Mode ➔"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </ToolBar>

                <ToolBar fx:id="algoToolbar" visible="false"
                         style="-fx-background-color: #ffffff; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0; -fx-padding: 12 15;">

                    <Button text="⬅ Build Mode" onAction="#switchToBuildMode"
                            style="-fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #374151; -fx-cursor: hand; -fx-font-weight: bold;"/>

                    <Separator style="-fx-padding: 0 5 0 5;" />

                    <ComboBox fx:id="algoComboBox" prefWidth="230" promptText="Select Algorithm"
                              style="-fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-cursor: hand;"/>

                    <Separator style="-fx-padding: 0 5 0 5;" />

                    <Label text="Value:" style="-fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                    <TextField fx:id="startNodeField" onAction="#togglePlayPause" prefWidth="120" promptText="Search Value"
                               style="-fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 4;"/>
                </ToolBar>
            </StackPane>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" pannable="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <BorderPane.margin>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
            </BorderPane.margin>
            <Pane fx:id="canvasPane" onMouseClicked="#handleCanvasClick" prefHeight="560" prefWidth="950"
                  style="-fx-background-color: #ffffff; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 0, 4);" />
        </ScrollPane>
    </center>

    <bottom>
        <VBox>
            <ToolBar style="-fx-background-color: linear-gradient(to right, #1e293b, #334155); -fx-alignment: center; -fx-padding: 10;">
                <Label fx:id="resultLabel" text=""
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
            </ToolBar>

            <ToolBar fx:id="playbackToolbar" managed="false" visible="false"
                     style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0; -fx-alignment: center; -fx-padding: 12 20; -fx-spacing: 15;">

                <Button onAction="#stepBackward" text="⏮"
                        prefHeight="35.0" prefWidth="45.0"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #111827; -fx-background-radius: 6; -fx-cursor: hand;"/>

                <Button fx:id="playPauseButton" onAction="#togglePlayPause" text="▶"
                        prefHeight="35.0" minWidth="65.0"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Button onAction="#stepForward" text="⏭"
                        prefHeight="35.0" prefWidth="45.0"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #111827; -fx-background-radius: 6; -fx-cursor: hand;"/>

                <Pane prefWidth="20.0" />
                <Button onAction="#resetAlgorithmState" text="↺ Reset"
                        prefHeight="35.0"
                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>

                <Pane prefWidth="20.0" />
                <Label text="Speed:" style="-fx-font-weight: bold; -fx-text-fill: #4b5563; -fx-font-size: 14px;"/>
                <Slider fx:id="speedSlider" blockIncrement="0.25" majorTickUnit="1.0" max="4.0" min="0.25"
                        prefHeight="35.0" prefWidth="150.0" showTickLabels="true" showTickMarks="true" value="1.0" />
            </ToolBar>
        </VBox>
    </bottom>

</BorderPane>