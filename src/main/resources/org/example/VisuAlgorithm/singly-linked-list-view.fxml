<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.FlowPane?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.VisuAlgorithm.SinglyLinkedListController"
            style="-fx-background-color: #eef2ff;">

    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #1e293b, #334155);">
                <padding>
                    <Insets top="12" right="16" bottom="12" left="16"/>
                </padding>

                <Button text="← Back"
                        onAction="#onBack"
                        style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                <Label text="Singly Linked List"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="headerStatusLabel"
                       text="Ready."
                       style="-fx-text-fill: #dbeafe;"/>

                <Region prefWidth="15"/>

                <Button fx:id="screenshotBtn" onAction="#takeScreenshot" prefHeight="32.0"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 6;"/>
                <Button fx:id="recordBtn" onAction="#toggleRecording" prefHeight="32.0"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 6;"/>
            </HBox>

            <VBox spacing="15" style="-fx-background-color: #f8fafc;">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>

                <FlowPane hgap="10" vgap="10" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Value:" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="valueField" promptText="val" prefWidth="60"/>

                        <Label text="Index:" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="indexField" promptText="idx" prefWidth="60"/>

                        <Button text="Insert Head" onAction="#onInsertHead" styleClass="ll-button"/>
                        <Button text="Insert Tail" onAction="#onInsertTail" styleClass="ll-button"/>
                        <Button text="Insert At" onAction="#onInsertAt" styleClass="ll-button"/>
                        <Button text="Random" onAction="#onRandom" styleClass="ll-button"/>

                        <Button text="Delete Head" onAction="#onDeleteHead" styleClass="ll-button, lldanger-button"/>
                        <Button text="Delete Tail" onAction="#onDeleteTail" styleClass="ll-button, lldanger-button"/>
                        <Button text="Clear" onAction="#onClear" styleClass="ll-button, lldanger-button"/>

                        <Button text="Search" onAction="#onSearch" styleClass="ll-button"/>
                        <Button text="Sort" onAction="#onSort" styleClass="ll-button"/>
                    </children>
                </FlowPane>

                <Label fx:id="statusLabel" text="Ready." style="-fx-text-fill: #64748b; -fx-font-style: italic;"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <ScrollPane pannable="true"
                    fitToWidth="false"
                    fitToHeight="false"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED">
            <Pane fx:id="canvas"
                  prefWidth="1800"
                  prefHeight="700"
                  style="-fx-background-color: linear-gradient(to bottom, #eef2ff, #f8fafc);"/>
        </ScrollPane>
    </center>

</BorderPane>