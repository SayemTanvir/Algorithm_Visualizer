<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.VisuAlgorithm.StackController"
            style="-fx-background-color: #eef2ff;">

    <top>
        <VBox spacing="0">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT"
                  spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #1e293b, #334155);">
                <padding>
                    <Insets top="12" right="16" bottom="12" left="16"/>
                </padding>

                <Button text="← Back"
                        onAction="#onBack"
                        style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 8 16 8 16;"/>

                <Label text="Stack"
                       textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0"/>
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="headerStatusLabel"
                       text="Ready."
                       textFill="#dbeafe"/>
            </HBox>

            <!-- Controls -->
            <VBox spacing="10" style="-fx-background-color: white;">
                <padding>
                    <Insets top="12" right="16" bottom="12" left="16"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Value:"/>
                    <TextField fx:id="valueField" promptText="value" prefWidth="100"/>

                    <Button text="Push"
                            onAction="#onPush"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Button text="Pop"
                            onAction="#onPop"
                            style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Button text="Peek"
                            onAction="#onPeek"
                            style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Button text="Random"
                            onAction="#onRandom"
                            style="-fx-background-color: black; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Button text="Search"
                            onAction="#onSearch"
                            style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Button text="Traverse"
                            onAction="#onTraverse"
                            style="-fx-background-color: #ea580c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Button text="Clear"
                            onAction="#onClear"
                            style="-fx-background-color: #475569; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Top:"/>
                    <Label fx:id="topLabel" text="-1"/>
                </HBox>

                <Label fx:id="statusLabel" text="Ready."/>
            </VBox>
        </VBox>
    </top>

    <center>
        <Pane fx:id="canvas"
              prefWidth="1000"
              prefHeight="1200"
              style="-fx-background-color: linear-gradient(to bottom, #eef2ff, #f8fafc);"/>
    </center>

</BorderPane>