<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.VisuAlgorithm.SortingController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #1e005e;" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="20.0" />
         </padding>
         <children>
            <Button mnemonicParsing="false" onAction="#backToHome" text="Back" />
            <Label text="Sorting Visualization" textFill="#ff7272">
               <font>
                  <Font size="37.0" />
               </font>
            </Label>
         </children>
      </HBox>
   </top>
   <right>
      <VBox prefHeight="340.0" prefWidth="80.0" spacing="5.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="10.0" bottom="10.0" left="5.0" right="5.0" />
         </padding>
         <children>
            <Button mnemonicParsing="false" onAction="#runSelectionSort" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Selection Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
            <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#runInsertionSort" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Insertion Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
            <Button fx:id="bubbleSortBtn" layoutX="10.0" layoutY="52.0" mnemonicParsing="false" onAction="#runBubbleSort" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Bubble Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
            <Button layoutX="10.0" layoutY="95.0" mnemonicParsing="false" onAction="#runMergeSort" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Merge Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
            <Button layoutX="10.0" layoutY="137.0" mnemonicParsing="false" onAction="#runQuickSort" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Quick Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
            <Button layoutX="10.0" layoutY="180.0" mnemonicParsing="false" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Counting Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
            <Button layoutX="10.0" layoutY="222.0" mnemonicParsing="false" prefWidth="70.0" style="-fx-background-color: #36a5c7;" text="Heap   Sort" textAlignment="CENTER" textFill="#0d0084" wrapText="true">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </right>
   <center>
      <Pane fx:id="displayPane" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </center>
   <left>
      <VBox prefHeight="400.0" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="10.0" left="10.0" right="10.0" bottom="10.0" />
         </padding>
         <children>
            <Label fx:id="sizeLabel" prefHeight="24.0" prefWidth="180.0" text="Array Size: 10" textAlignment="CENTER" />
            <Slider fx:id="sizeSlider" majorTickUnit="5.0" max="25.0" min="1.0" minorTickCount="1" showTickLabels="true" snapToTicks="true" value="10.0" />
            <Button mnemonicParsing="false" onAction="#generateRandomArray" prefWidth="180.0" text="Random Generate" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="12.0" />
               </font>
            </Button>
            <Label prefHeight="18.0" prefWidth="180.0" text="Custom Input:">
               <font>
                  <Font size="13.0" />
               </font>
            </Label>
            <TextField fx:id="customInput" prefWidth="180.0" text="5, 12, 8, 2, 10" />
            <Button mnemonicParsing="false" onAction="#loadCustomInput" prefHeight="26.0" prefWidth="180.0" text="Load Input" />

            <Separator prefWidth="180.0">
               <VBox.margin>
                  <Insets top="10.0" bottom="5.0" />
               </VBox.margin>
            </Separator>

            <Label text="Live Status Update" textFill="#1e005e">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Label fx:id="algoNameLabel" prefWidth="180.0" text="Algorithm: None" textFill="#0d0084" wrapText="true">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label fx:id="currentStepLabel" prefWidth="180.0" text="Action: -" textFill="#ff7272" wrapText="true" />
            <TextArea fx:id="stepDescriptionArea" editable="false" prefHeight="120.0" prefWidth="180.0" promptText="Algorithm details..." wrapText="true" />

         </children>
      </VBox>
   </left>
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="600.0" spacing="15.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
         <children>
            <Button fx:id="stepBackBtn" mnemonicParsing="false" onAction="#stepBackward" prefHeight="30.0" prefWidth="40.0" text="⏮" />
            <Button fx:id="playPauseBtn" mnemonicParsing="false" onAction="#togglePlayPause" prefHeight="30.0" prefWidth="40.0" text="▶" />
            <Button fx:id="skipBtn" mnemonicParsing="false" onAction="#stepForward" prefHeight="30.0" prefWidth="40.0" text="⏭" />
            <Pane prefHeight="50.0" prefWidth="30.0" /> <Label text="Speed">
            <font>
               <Font size="16.0" />
            </font>
         </Label>
            <Slider fx:id="speedSlider" max="10.0" prefHeight="35.0" prefWidth="180.0" />
         </children>
      </HBox>
   </bottom>
</BorderPane>