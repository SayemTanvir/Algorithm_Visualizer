<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.VisuAlgorithm.LinkedListController">

    <!-- Non-visual objects MUST be in fx:define -->
    <fx:define>
        <ToggleGroup fx:id="modeGroup"/>
    </fx:define>

    <!-- ===== TOP (Header + Toolbar) ===== -->
    <top>
        <VBox>

            <!-- Header Bar (match your other modules by changing these colors) -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #0f172a;">
                <padding>
                    <Insets top="10" right="12" bottom="10" left="12"/>
                </padding>

                <Button fx:id="backBtn"
                        text="← Back"
                        onAction="#onBack"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Label text="Linked List"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="headerStatusLabel"
                       text=""
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Toolbar Panel -->
            <VBox spacing="10"
                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>

                <!-- Row 1: Mode + Node ops -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Mode:" style="-fx-font-weight: bold;"/>

                    <RadioButton fx:id="rbSingly"
                                 text="Singly"
                                 toggleGroup="$modeGroup"
                                 selected="true"
                                 onAction="#onModeChanged"/>

                    <RadioButton fx:id="rbDoubly"
                                 text="Doubly"
                                 toggleGroup="$modeGroup"
                                 onAction="#onModeChanged"/>

                    <RadioButton fx:id="rbMulti"
                                 text="Multi"
                                 toggleGroup="$modeGroup"
                                 onAction="#onModeChanged"/>

                    <Separator prefWidth="18"/>

                    <Label text="Value:"/>
                    <TextField fx:id="valueField" promptText="int" prefWidth="90"/>

                    <Button text="Insert Head" onAction="#onInsertHead"/>
                    <Button text="Insert Tail" onAction="#onInsertTail"/>

                    <Separator prefWidth="18"/>

                    <Label text="Delete idx:"/>
                    <TextField fx:id="deleteIndexField" promptText="index" prefWidth="80"/>
                    <Button text="Delete" onAction="#onDeleteIndex"/>

                    <Button text="Clear All"
                            onAction="#onClearAll"
                            style="-fx-background-color: #fee2e2; -fx-text-fill: #991b1b; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Row 2: Edge builder -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Edge Builder:" style="-fx-font-weight: bold;"/>

                    <Label text="from"/>
                    <TextField fx:id="fromField" promptText="idx" prefWidth="70"/>

                    <Label text="to"/>
                    <TextField fx:id="toField" promptText="idx" prefWidth="70"/>

                    <Label text="op"/>
                    <ChoiceBox fx:id="edgeOpChoice" prefWidth="90"/>

                    <Button text="Apply" onAction="#onApplyEdge"/>

                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="modeHintLabel" text="" opacity="0.8"/>
                </HBox>

                <Label fx:id="statusLabel" text="" opacity="0.85"/>
            </VBox>

        </VBox>
    </top>

    <!-- ===== CENTER (Scrollable Canvas) ===== -->
    <center>
        <ScrollPane fx:id="scroll"
                    fitToWidth="true"
                    fitToHeight="true"
                    pannable="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background: blue;">
            <content>
                <!-- Big preferred size so scrolling works for long lists -->
                <Pane fx:id="canvas"
                      prefWidth="2200"
                      prefHeight="900"
                      style="-fx-background-color: black;"/>
            </content>
        </ScrollPane>
    </center>

</BorderPane>